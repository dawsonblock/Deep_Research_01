{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NormalizedClaimSet",
  "description": "A set of normalized, deduplicated claims with provenance.",
  "type": "object",
  "required": ["claims"],
  "properties": {
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["claim_id", "text", "confidence", "provenance"],
        "properties": {
          "claim_id": {
            "type": "string",
            "description": "Unique identifier for the normalized claim"
          },
          "text": {
            "type": "string",
            "minLength": 1,
            "description": "The normalized claim text"
          },
          "original_text": {
            "type": "string",
            "description": "The original claim text before normalization"
          },
          "claim_type": {
            "type": "string",
            "enum": ["assertion", "causal", "correlational", "comparative", "definitional"],
            "description": "The classification of the claim"
          },
          "confidence": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0,
            "description": "Confidence score for the claim"
          },
          "provenance": {
            "type": "object",
            "required": ["source_passage_id"],
            "properties": {
              "source_passage_id": {
                "type": "string",
                "description": "ID of the source passage"
              },
              "source_offset": {
                "type": "integer",
                "description": "Character offset in the original document"
              },
              "candidate_id": {
                "type": "string",
                "description": "ID of the original claim candidate"
              },
              "document_id": {
                "type": "string",
                "description": "ID of the source document"
              }
            },
            "description": "Provenance information for traceability"
          },
          "metadata": {
            "type": "object",
            "description": "Additional metadata"
          }
        }
      }
    },
    "claim_count": {
      "type": "integer",
      "minimum": 0
    },
    "document_id": {
      "type": "string"
    },
    "deduplicated_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of candidates removed during deduplication"
    }
  }
}
