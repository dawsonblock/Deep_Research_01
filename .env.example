RESEARCH_ENGINE_DB_PATH=data/research_engine.db
SEARXNG_BASE_URL=
SEARXNG_TIMEOUT_SECONDS=8
RUN_LOOP_MAX_STEPS=50

LLM_PROVIDER=none
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4.1-mini
LLM_TIMEOUT_SECONDS=20

EMBEDDING_PROVIDER=local_hash
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=256

OPENSANDBOX_ENABLED=false
OPEN_SANDBOX_DOMAIN=
OPEN_SANDBOX_API_KEY=
OPEN_SANDBOX_PROTOCOL=http
OPEN_SANDBOX_TIMEOUT_SECONDS=180
OPEN_SANDBOX_USE_SERVER_PROXY=false
OPEN_SANDBOX_DEFAULT_IMAGE=ubuntu:22.04
OPEN_SANDBOX_PYTHON_IMAGE=python:3.11-slim
OPEN_SANDBOX_DEFAULT_WORKDIR=/workspace
OPEN_SANDBOX_SESSION_TTL_MINUTES=30
OPEN_SANDBOX_REPO_DIR=/workspace/repo
